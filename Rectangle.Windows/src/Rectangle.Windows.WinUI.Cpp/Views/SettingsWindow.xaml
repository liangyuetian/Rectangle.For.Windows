<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Rectangle.Windows.WinUI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Rectangle 设置"
    Width="800"
    Height="600"
    MinWidth="600"
    MinHeight="400"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0078D4">
            <TextBlock Text="Rectangle 设置"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel Spacing="24">
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="常规设置" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="边距:" VerticalAlignment="Center" Width="80"/>
                    <NumberBox x:Name="GapSizeBox"
                               Width="120"
                               Minimum="0"
                               Maximum="50"
                               Value="0"
                               ValueChanged="GapSizeBox_ValueChanged"/>
                    <TextBlock Text="像素" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="启动登录:" VerticalAlignment="Center" Width="80"/>
                    <ToggleSwitch x:Name="LaunchOnLoginToggle"
                                  Toggled="LaunchOnLoginToggle_Toggled"/>
                </StackPanel>

                <Border Height="1" Background="#E0E0E0" Margin="0,8"/>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="快捷键设置" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel x:Name="ShortcutsPanel" Spacing="16">
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>