<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <EnableMsixTooling>true</EnableMsixTooling>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <LinkDebugInformation>true</LinkDebugInformation>
    <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
    <Optimization>Disabled</Optimization>
    <BasicRuntimeChecks>EnableFastChecks</BasicRuntimeChecks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <LinkDebugInformation>false</LinkDebugInformation>
    <DebugInformationFormat>None</DebugInformationFormat>
    <Optimization>MaxSpeed</Optimization>
    <IntrinsicFunctions>true</IntrinsicFunctions>
    <FavorSizeOrSpeed>Speed</FavorSizeOrSpeed>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <PrecompiledHeaderOutputFile>$(IntDir)pch.pch</PrecompiledHeaderOutputFile>
      <WarningLevel>Level4</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <ConformanceMode>true</ConformanceMode>
      <AdditionalIncludeDirectories>$(ProjectDir);$(IntermediateOutputPath);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <AdditionalDependencies>user32.lib;kernel32.lib;shell32.lib;ole32.lib;gdi32.lib;comdlg32.lib;advapi32.lib;shell32.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalOptions>/DYNAMICBASE %(AdditionalOptions)</AdditionalOptions>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
    <ResourceCompile>
      <AdditionalIncludeDirectories>$(ProjectDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ResourceCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClInclude Include="App.h" />
    <ClInclude Include="Core\Enums.h" />
    <ClInclude Include="Core\WindowRect.h" />
    <ClInclude Include="Core\IRectCalculator.h" />
    <ClInclude Include="Core\CalculatorFactory.h" />
    <ClInclude Include="Core\RepeatedExecutionsCalculator.h" />
    <ClInclude Include="Core\WindowHistory.h" />
    <ClInclude Include="Core\WindowAction.h" />
    <ClInclude Include="Services\ConfigService.h" />
    <ClInclude Include="Services\Logger.h" />
    <ClInclude Include="Services\Win32WindowService.h" />
    <ClInclude Include="Services\HotkeyManager.h" />
    <ClInclude Include="Services\WindowManager.h" />
    <ClInclude Include="Services\ScreenDetectionService.h" />
    <ClInclude Include="Services\WindowTypeService.h" />
    <ClInclude Include="Services\LastActiveWindowService.h" />
    <ClInclude Include="Services\SnapDetectionService.h" />
    <ClInclude Include="Services\TrayIconService.h" />
    <ClInclude Include="Services\ThemeService.h" />
    <ClInclude Include="Services\WindowEnumerator.h" />
    <ClInclude Include="Services\OperationHistoryManager.h" />
    <ClInclude Include="Core\Calculators\HalfCalculators.h" />
    <ClInclude Include="Core\Calculators\CornerCalculators.h" />
    <ClInclude Include="Core\Calculators\ThirdCalculators.h" />
    <ClInclude Include="Core\Calculators\FourthCalculators.h" />
    <ClInclude Include="Core\Calculators\SixthCalculators.h" />
    <ClInclude Include="Core\Calculators\EighthCalculators.h" />
    <ClInclude Include="Core\Calculators\MoveCalculators.h" />
    <ClInclude Include="Core\Calculators\MiscCalculators.h" />
  </ItemGroup>

  <ItemGroup>
    <ClCompile Include="pch.cpp" />
    <ClCompile Include="main.cpp" />
    <ClCompile Include="App.cpp" />
    <ClCompile Include="Core\Enums.cpp" />
    <ClCompile Include="Core\WindowRect.cpp" />
    <ClCompile Include="Core\CalculatorFactory.cpp" />
    <ClCompile Include="Core\RepeatedExecutionsCalculator.cpp" />
    <ClCompile Include="Core\WindowHistory.cpp" />
    <ClCompile Include="Core\WindowAction.cpp" />
    <ClCompile Include="Services\ConfigService.cpp" />
    <ClCompile Include="Services\Logger.cpp" />
    <ClCompile Include="Services\Win32WindowService.cpp" />
    <ClCompile Include="Services\HotkeyManager.cpp" />
    <ClCompile Include="Services\WindowManager.cpp" />
    <ClCompile Include="Services\ScreenDetectionService.cpp" />
    <ClCompile Include="Services\WindowTypeService.cpp" />
    <ClCompile Include="Services\LastActiveWindowService.cpp" />
    <ClCompile Include="Services\SnapDetectionService.cpp" />
    <ClCompile Include="Services\TrayIconService.cpp" />
    <ClCompile Include="Services\ThemeService.cpp" />
    <ClCompile Include="Services\WindowEnumerator.cpp" />
    <ClCompile Include="Services\OperationHistoryManager.cpp" />
    <ClCompile Include="Core\Calculators\HalfCalculators.cpp" />
    <ClCompile Include="Core\Calculators\CornerCalculators.cpp" />
    <ClCompile Include="Core\Calculators\ThirdCalculators.cpp" />
    <ClCompile Include="Core\Calculators\FourthCalculators.cpp" />
    <ClCompile Include="Core\Calculators\SixthCalculators.cpp" />
    <ClCompile Include="Core\Calculators\EighthCalculators.cpp" />
    <ClCompile Include="Core\Calculators\MoveCalculators.cpp" />
    <ClCompile Include="Core\Calculators\MiscCalculators.cpp" />
  </ItemGroup>

  <ItemGroup>
    <None Include="app.manifest" />
    <None Include="Package.appxmanifest" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
