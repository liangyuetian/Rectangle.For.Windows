<?xml version="1.0" encoding="UTF-8"?>
<Page
    x:Class="Rectangle.Windows.WinUI.Rust.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="16">
            <TextBlock Text="通用设置" Style="{StaticResource TitleTextBlockStyle}" />

            <TextBlock Text="外观" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ComboBox Header="主题" x:Name="ThemeComboBox" SelectedIndex="0">
                <ComboBoxItem>系统默认</ComboBoxItem>
                <ComboBoxItem>浅色</ComboBoxItem>
                <ComboBoxItem>深色</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="布局" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0" />
            <Slider Header="间隙大小" x:Name="GapSizeSlider" Minimum="0" Maximum="20" Value="0" />
            <Slider Header="水平分割比例" x:Name="HorizontalSplitSlider" Minimum="30" Maximum="70" Value="50" />
            <Slider Header="垂直分割比例" x:Name="VerticalSplitSlider" Minimum="30" Maximum="70" Value="50" />

            <TextBlock Text="动画" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0" />
            <ToggleSwitch Header="启用动画" x:Name="AnimationToggle" IsOn="True" />
            <Slider Header="动画持续时间 (ms)" x:Name="AnimationDurationSlider" Minimum="50" Maximum="500" Value="200" />

            <TextBlock Text="启动" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0" />
            <ToggleSwitch Header="开机启动" x:Name="LaunchOnLoginToggle" IsOn="False" />

            <TextBlock Text="日志" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0" />
            <ToggleSwitch Header="启用日志文件" x:Name="LogToFileToggle" IsOn="False" />
            <ComboBox Header="日志级别" x:Name="LogLevelComboBox" SelectedIndex="1">
                <ComboBoxItem>调试</ComboBoxItem>
                <ComboBoxItem>信息</ComboBoxItem>
                <ComboBoxItem>警告</ComboBoxItem>
                <ComboBoxItem>错误</ComboBoxItem>
            </ComboBox>
        </StackPanel>
    </ScrollViewer>
</Page>
