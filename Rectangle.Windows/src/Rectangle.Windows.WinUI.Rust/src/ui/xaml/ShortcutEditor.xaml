<?xml version="1.0" encoding="UTF-8"?>
<UserControl
    x:Class="Rectangle.Windows.WinUI.Rust.ShortcutEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="100" />
            <ColumnDefinition Width="*" MinWidth="120" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="{x:Bind Label}" VerticalAlignment="Center" />

        <TextBox Grid.Column="1"
                 x:Name="ShortcutTextBox"
                 IsReadOnly="True"
                 PlaceholderText="无快捷键"
                 Tapped="OnTextBoxTapped"
                 KeyDown="OnKeyDown" />

        <ToggleSwitch Grid.Column="2" x:Name="EnabledToggle" IsOn="True" />
    </Grid>
</UserControl>
