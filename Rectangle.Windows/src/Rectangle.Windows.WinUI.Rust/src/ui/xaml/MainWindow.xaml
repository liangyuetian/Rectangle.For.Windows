<?xml version="1.0" encoding="UTF-8"?>
<Window
    x:Class="Rectangle.Windows.WinUI.Rust.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Rectangle.Windows.WinUI.Rust"
    Title="Rectangle 设置"
    Width="900"
    Height="600"
    MinWidth="600"
    MinHeight="400">

    <NavigationView x:Name="NavView" PaneDisplayMode="Left">
        <NavigationView.MenuItems>
            <NavigationViewItem Icon="Keyboard" Content="快捷键" Tag="Shortcuts" />
            <NavigationViewItem Icon="ViewAll" Content="吸附区域" Tag="SnapAreas" />
            <NavigationViewItem Icon="Setting" Content="通用设置" Tag="General" />
        </NavigationView.MenuItems>

        <NavigationView.Header>
            <TextBlock x:Name="HeaderText" Text="快捷键设置" Style="{StaticResource TitleTextBlockStyle}" />
        </NavigationView.Header>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
