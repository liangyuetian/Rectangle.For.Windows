<?xml version="1.0" encoding="UTF-8"?>
<Window
    x:Class="Rectangle.Windows.WinUI.Views.LogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="日志查看器"
    Width="900"
    Height="600"
    MinWidth="600"
    MinHeight="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="Refresh" Label="刷新" Click="Refresh_Click"/>
            <AppBarButton Icon="Clear" Label="清空" Click="Clear_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Save" Label="导出" Click="Export_Click"/>
            <AppBarSeparator/>
            <AppBarToggleButton x:Name="AutoScrollButton" Icon="Sort" Label="自动滚动" IsChecked="True"/>
        </CommandBar>

        <!-- 日志内容 -->
        <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer">
            <TextBox x:Name="LogTextBox"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    FontFamily="Consolas"
                    FontSize="12"
                    BorderThickness="0"
                    Background="Transparent"/>
        </ScrollViewer>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="LineCountText" Text="0 行"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
