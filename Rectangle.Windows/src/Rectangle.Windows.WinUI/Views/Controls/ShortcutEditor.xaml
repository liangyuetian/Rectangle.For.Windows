<?xml version="1.0" encoding="UTF-8"?>
<UserControl
    x:Class="Rectangle.Windows.WinUI.Views.Controls.ShortcutEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="48" Padding="8,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 图标 (使用 Segoe Fluent Icons) -->
        <FontIcon Grid.Column="0"
                 x:Name="IconFont"
                 Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                 FontSize="18"
                 Margin="0,0,12,0"
                 VerticalAlignment="Center"
                 Foreground="{StaticResource AccentBrush}"/>

        <!-- 名称 -->
        <TextBlock Grid.Column="1"
                  Text="{x:Bind DisplayName, Mode=OneWay}"
                  VerticalAlignment="Center"
                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

        <!-- 快捷键显示/输入按钮 -->
        <Button Grid.Column="2"
               x:Name="ShortcutButton"
               Content="{x:Bind ShortcutText, Mode=OneWay}"
               Style="{StaticResource ShortcutInputStyle}"
               Click="ShortcutButton_Click"
               ToolTipService.ToolTip="点击设置快捷键"/>

        <!-- 清除按钮 -->
        <Button Grid.Column="3"
               x:Name="ClearButton"
               Content="&#xE711;"
               Style="{StaticResource ClearButtonStyle}"
               Click="ClearButton_Click"
               FontFamily="Segoe Fluent Icons"
               ToolTipService.ToolTip="清除快捷键"/>
    </Grid>
</UserControl>
