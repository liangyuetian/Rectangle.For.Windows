<?xml version="1.0" encoding="UTF-8"?>
<UserControl
    x:Class="Rectangle.Windows.WinUI.Views.Controls.ShortcutEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="48" Padding="8,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <FontIcon Grid.Column="0"
                  Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                  FontSize="18" Margin="0,0,12,0"
                  VerticalAlignment="Center"
                  Foreground="{StaticResource AccentBrush}"/>

        <TextBlock Grid.Column="1"
                   Text="{x:Bind DisplayName, Mode=OneWay}"
                   VerticalAlignment="Center"/>

        <!-- 快捷键显示：右侧显示当前快捷键（使用 Binding 以正确响应 DataContext 中 ShortcutItem.ShortcutText 的更新） -->
        <TextBlock Grid.Column="2"
                   Text="{Binding ShortcutText, Mode=OneWay}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"
                   FontSize="13"
                   Foreground="{ThemeResource TextFillColorSecondary}"/>

        <Button Grid.Column="3"
                x:Name="ShortcutButton"
                Content="记录"
                Style="{StaticResource ShortcutInputStyle}"
                Click="ShortcutButton_Click"/>

        <Button Grid.Column="4"
                x:Name="ClearButton"
                Content="&#xE711;"
                Style="{StaticResource ClearButtonStyle}"
                Click="ClearButton_Click"
                FontFamily="Segoe Fluent Icons"
                Visibility="Collapsed"/>
    </Grid>
</UserControl>
