<?xml version="1.0" encoding="UTF-8"?>
<UserControl
    x:Class="Rectangle.Windows.WinUI.Views.Controls.AnimatedCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="CardBorder"
            Background="{ThemeResource CardBackgroundBrush}"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardBorderBrush}"
            Padding="16"
            Margin="0,0,0,16">

        <Border.Resources>
            <Storyboard x:Name="HoverInStoryboard">
                <ColorAnimation Storyboard.TargetName="CardBorder"
                               Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                               To="{ThemeResource CardBackgroundHoverColor}"
                               Duration="0:0:0.15"/>
                <DoubleAnimation Storyboard.TargetName="CardScale"
                                Storyboard.TargetProperty="ScaleX"
                                 To="1.01"
                                Duration="0:0:0.15"/>
                <DoubleAnimation Storyboard.TargetName="CardScale"
                                Storyboard.TargetProperty="ScaleY"
                                To="1.01"
                                Duration="0:0:0.15"/>
            </Storyboard>

            <Storyboard x:Name="HoverOutStoryboard">
                <ColorAnimation Storyboard.TargetName="CardBorder"
                               Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                               To="{ThemeResource CardBackgroundColor}"
                               Duration="0:0:0.15"/>
                <DoubleAnimation Storyboard.TargetName="CardScale"
                                Storyboard.TargetProperty="ScaleX"
                                To="1.0"
                                Duration="0:0:0.15"/>
                <DoubleAnimation Storyboard.TargetName="CardScale"
                                Storyboard.TargetProperty="ScaleY"
                                To="1.0"
                                Duration="0:0:0.15"/>
            </Storyboard>
        </Border.Resources>

        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
        </Border.RenderTransform>

        <ContentPresenter x:Name="CardContent"
                         Content="{x:Bind Content, Mode=OneWay}"/>
    </Border>
</UserControl>
