<?xml version="1.0" encoding="UTF-8"?>
<UserControl
    x:Class="Rectangle.Windows.WinUI.Views.Controls.SnapAreaPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource InputBackgroundBrush}"
          CornerRadius="8"
          BorderBrush="{ThemeResource CardBorderBrush}"
          BorderThickness="1">

        <Grid x:Name="ScreenPreview"
              Margin="40,30"
              Background="{ThemeResource CardBackgroundBrush}"
              CornerRadius="4"
              BorderBrush="{ThemeResource CardBorderBrush}"
              BorderThickness="1">

            <Border x:Name="LeftHalfArea"
                    Background="Transparent"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2" CornerRadius="2"
                    HorizontalAlignment="Left" Width="100" Height="100%"
                    Opacity="0.3"
                    PointerEntered="Area_PointerEntered"
                    PointerExited="Area_PointerExited">
                <TextBlock Text="左半屏" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"/>
            </Border>

            <Border x:Name="RightHalfArea"
                    Background="Transparent"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2" CornerRadius="2"
                    HorizontalAlignment="Right" Width="100" Height="100%"
                    Opacity="0.3"
                    PointerEntered="Area_PointerEntered"
                    PointerExited="Area_PointerExited">
                <TextBlock Text="右半屏" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
