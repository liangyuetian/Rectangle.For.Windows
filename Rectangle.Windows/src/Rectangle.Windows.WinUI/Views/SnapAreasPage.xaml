<?xml version="1.0" encoding="UTF-8"?>
<Page
    x:Class="Rectangle.Windows.WinUI.Views.SnapAreasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Rectangle.Windows.WinUI.Views.Controls"
    xmlns:local="using:Rectangle.Windows.WinUI.Views"
    x:DataType="local:SnapAreasPage"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="40,30" Spacing="20" MaxWidth="700" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="吸附区域" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="配置窗口拖拽吸附行为" Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel Spacing="16">
                    <ToggleSwitch Header="拖移以吸附"
                                 OffContent="关闭" OnContent="开启"
                                 IsOn="{x:Bind ViewModel.DragToSnap, Mode=TwoWay}"/>
                    <ToggleSwitch Header="结束吸附时恢复窗口大小"
                                 OffContent="关闭" OnContent="开启"
                                 IsOn="{x:Bind ViewModel.RestoreSizeOnSnapEnd, Mode=TwoWay}"/>
                    <ToggleSwitch Header="显示吸附预览动画"
                                 OffContent="关闭" OnContent="开启"
                                 IsOn="{x:Bind ViewModel.SnapAnimation, Mode=TwoWay}"/>
                    <ToggleSwitch Header="吸附时触觉反馈"
                                 OffContent="关闭" OnContent="开启"
                                 IsOn="{x:Bind ViewModel.HapticFeedback, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="窗口间隙" Style="{StaticResource CardTitleStyle}"/>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,60">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="窗口之间的间距"
                                      Foreground="{StaticResource SecondaryTextBrush}"
                                      FontSize="13"/>
                        </StackPanel>
                        <Slider Grid.Column="1" Width="200" Minimum="0" Maximum="30"
                               Value="{x:Bind ViewModel.GapSize, Mode=TwoWay}"
                               VerticalAlignment="Center" Margin="16,0"/>
                        <TextBlock Grid.Column="2"
                                  Text="{x:Bind ViewModel.GapSize, Mode=OneWay}"
                                  VerticalAlignment="Center" HorizontalAlignment="Right"
                                  Foreground="{StaticResource SecondaryTextBrush}"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel>
                    <TextBlock Text="吸附区域示意" Style="{StaticResource CardTitleStyle}"/>
                    <controls:SnapAreaPreview Width="600" Height="240" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
