<?xml version="1.0" encoding="UTF-8"?>
<Page
    x:Class="Rectangle.Windows.WinUI.Views.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Rectangle.Windows.WinUI.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="40,30" Spacing="20" MaxWidth="700" HorizontalAlignment="Left">
            <!-- 页面标题 -->
            <StackPanel>
                <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="通用设置和偏好选项" Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>

            <!-- 外观设置卡片 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="外观" Style="{StaticResource CardTitleStyle}"/>

                    <!-- 主题选择 -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="主题"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="选择应用的颜色主题"
                                      FontSize="12"
                                      Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                 x:Name="ThemeComboBox"
                                 Width="150"
                                 VerticalAlignment="Center"
                                 SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="跟随系统" Tag="Default"/>
                            <ComboBoxItem Content="深色" Tag="Dark"/>
                            <ComboBoxItem Content="浅色" Tag="Light"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 通用设置卡片 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="通用" Style="{StaticResource CardTitleStyle}"/>

                    <ToggleSwitch Header="登录时打开"
                                 OffContent="关闭"
                                 OnContent="开启"
                                 x:Name="LaunchOnLoginToggle"
                                 Toggled="LaunchOnLoginToggle_Toggled"/>

                    <TextBlock Text="系统启动时自动运行 Rectangle"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontSize="13"
                              Margin="0,-8,0,0"/>

                    <Border Background="{ThemeResource CardBorderBrush}"
                           Height="1"
                           Margin="0,8"/>

                    <!-- 语言设置 -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="语言"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="选择界面显示语言"
                                      FontSize="12"
                                      Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                 Width="150"
                                 VerticalAlignment="Center"
                                 SelectedIndex="0">
                            <ComboBoxItem Content="简体中文"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 高级设置卡片 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="高级" Style="{StaticResource CardTitleStyle}"/>

                    <ToggleSwitch Header="启用日志"
                                 OffContent="关闭"
                                 OnContent="开启"
                                 IsOn="{x:Bind ViewModel.LogToFile, Mode=TwoWay}"/>

                    <TextBlock Text="记录应用运行日志到文件"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontSize="13"
                              Margin="0,-8,0,0"/>

                    <!-- 日志级别 -->
                    <!-- <Grid ColumnDefinitions="*,Auto" IsEnabled="{x:Bind ViewModel.LogToFile, Mode=OneWay}">
                        <TextBlock Grid.Column="0"
                                  Text="日志级别"
                                  VerticalAlignment="Center"/>
                        <ComboBox x:Name="LogLevelComboBox"
                                 Grid.Column="1"
                                 Width="120"
                                 SelectionChanged="LogLevelComboBox_SelectionChanged">
                            <ComboBoxItem Content="调试"/>
                            <ComboBoxItem Content="信息"/>
                            <ComboBoxItem Content="警告"/>
                            <ComboBoxItem Content="错误"/>
                        </ComboBox>
                    </Grid> -->
                    <Border Background="{ThemeResource CardBorderBrush}"
                           Height="1"
                           Margin="0,8"/>

                    <!-- 重置设置 -->
                    <Button Content="重置所有设置"
                           Click="ResetSettings_Click"
                           Style="{StaticResource RestoreButtonStyle}"
                           Margin="0"/>
                </StackPanel>
            </Border>

            <!-- 关于卡片 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="关于" Style="{StaticResource CardTitleStyle}"/>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <!-- 应用图标 -->
                        <FontIcon Glyph="&#xE737;"
                                 FontSize="48"
                                 Foreground="{StaticResource AccentBrush}"/>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rectangle for Windows"
                                      FontSize="18"
                                      FontWeight="SemiBold"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <TextBlock Text="版本 1.0.0 · 基于 macOS Rectangle 移植"
                                      Foreground="{StaticResource SecondaryTextBrush}"
                                      FontSize="13"/>

                            <HyperlinkButton Content="GitHub: rxhanson/Rectangle"
                                            NavigateUri="https://github.com/rxhanson/Rectangle"
                                            Margin="-12,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{ThemeResource CardBorderBrush}"
                           Height="1"
                           Margin="0,8"/>

                    <TextBlock Text="Rectangle 是一个开源的窗口管理工具，帮助您更高效地组织和管理窗口布局。"
                              FontSize="13"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <HyperlinkButton Content="查看文档"
                                        NavigateUri="https://github.com/rxhanson/Rectangle/blob/master/README.md"/>
                        <HyperlinkButton Content="报告问题"
                                        NavigateUri="https://github.com/rxhanson/Rectangle/issues"/>
                        <HyperlinkButton Content="检查更新"
                                        Click="CheckUpdate_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
