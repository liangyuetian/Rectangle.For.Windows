<?xml version="1.0" encoding="UTF-8"?>
<Application
    x:Class="Rectangle.Windows.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Rectangle.Windows.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 应用级别的资源覆盖 -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#181818"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
